{
  "name": "@agent-anything/agent-core",
  "version": "0.0.0",
  "description": "Agent runtime, loop, planner, context, events, and task contracts for AgentAnything platform packages.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    },
    "./runtime": {
      "types": "./src/runtime/index.ts",
      "import": "./dist/runtime/index.js"
    },
    "./planner": {
      "types": "./src/planner/index.ts",
      "import": "./dist/planner/index.js"
    },
    "./context": {
      "types": "./src/context/index.ts",
      "import": "./dist/context/index.js"
    },
    "./events": {
      "types": "./src/events/index.ts",
      "import": "./dist/events/index.js"
    },
    "./host": {
      "types": "./src/host/index.ts",
      "import": "./dist/host/index.js"
    },
    "./task": {
      "types": "./src/task/index.ts",
      "import": "./dist/task/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@agent-anything/evidence": "workspace:*",
    "@agent-anything/governance": "workspace:*",
    "@agent-anything/observability": "workspace:*",
    "@agent-anything/permission": "workspace:*",
    "@agent-anything/providers": "workspace:*",
    "@agent-anything/shared": "workspace:*",
    "@agent-anything/storage": "workspace:*",
    "@agent-anything/tools": "workspace:*"
  },
  "devDependencies": {
    "@agent-anything/testing": "workspace:*"
  },
  "license": "Apache-2.0",
  "private": true
}
