{
  "name": "@agent-anything/agent-core",
  "version": "0.0.0",
  "description": "Agent, controller, action, run, context, plan, retry, event, and task semantics for AgentAnything platform packages.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    },
    "./agent": {
      "types": "./src/agent/index.ts",
      "import": "./dist/agent/index.js"
    },
    "./action": {
      "types": "./src/action/index.ts",
      "import": "./dist/action/index.js"
    },
    "./controller": {
      "types": "./src/controller/index.ts",
      "import": "./dist/controller/index.js"
    },
    "./run": {
      "types": "./src/run/index.ts",
      "import": "./dist/run/index.js"
    },
    "./retry": {
      "types": "./src/retry/index.ts",
      "import": "./dist/retry/index.js"
    },
    "./plan": {
      "types": "./src/plan/index.ts",
      "import": "./dist/plan/index.js"
    },
    "./context": {
      "types": "./src/context/index.ts",
      "import": "./dist/context/index.js"
    },
    "./events": {
      "types": "./src/events/index.ts",
      "import": "./dist/events/index.js"
    },
    "./task": {
      "types": "./src/task/index.ts",
      "import": "./dist/task/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@agent-anything/governance": "workspace:*",
    "@agent-anything/permission": "workspace:*",
    "@agent-anything/shared": "workspace:*",
    "@agent-anything/tools": "workspace:*"
  },
  "devDependencies": {
    "@agent-anything/testing": "workspace:*"
  },
  "license": "Apache-2.0",
  "private": true
}
