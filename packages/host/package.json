{
  "name": "@agent-anything/host",
  "version": "0.0.0",
  "description": "Product-neutral host integration, safe Run projection, approval bridge, and host authority stores for AgentAnything.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@agent-anything/agent-core": "workspace:*",
    "@agent-anything/agent-runtime": "workspace:*",
    "@agent-anything/governance": "workspace:*",
    "@agent-anything/permission": "workspace:*",
    "@agent-anything/shared": "workspace:*"
  },
  "devDependencies": {
    "@agent-anything/providers": "workspace:*"
  },
  "license": "Apache-2.0",
  "private": true
}
