{
  "name": "@agent-anything/governance",
  "version": "0.0.0",
  "description": "Governance, policy, workspace, and identity contracts for AgentAnything platform packages.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    },
    "./policy": {
      "types": "./src/policy/index.ts",
      "import": "./dist/policy/index.js"
    },
    "./workspace": {
      "types": "./src/workspace/index.ts",
      "import": "./dist/workspace/index.js"
    },
    "./identity": {
      "types": "./src/identity/index.ts",
      "import": "./dist/identity/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "license": "Apache-2.0",
  "private": true,
  "dependencies": {
    "@agent-anything/permission": "workspace:*",
    "@agent-anything/shared": "workspace:*",
    "@agent-anything/tools": "workspace:*"
  }
}
