{
  "name": "net-doctor",
  "displayName": "NetDoctor",
  "version": "0.0.0",
  "publisher": "agent-anything",
  "type": "module",
  "description": "NetDoctor, a host-agnostic network diagnostic agent built on AgentAnything.",
  "categories": [
    "Other"
  ],
  "engines": {
    "vscode": "^1.90.0"
  },
  "main": "./dist/extension.js",
  "types": "./dist/extension.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./extension": {
      "types": "./dist/extension.d.ts",
      "import": "./dist/extension.js"
    }
  },
  "contributes": {
    "commands": [
      {
        "command": "netDoctor.diagnoseTarget",
        "title": "NetDoctor: Diagnose Target"
      }
    ]
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:extension": "pnpm run build && esbuild src/extension.ts --bundle --platform=node --format=esm --external:vscode --outfile=dist/extension.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "package": "vsce package --no-dependencies --allow-missing-repository --skip-license",
    "package:list": "vsce ls --tree --no-dependencies",
    "release:check": "pnpm run typecheck && pnpm run test && pnpm run build:extension && pnpm run package",
    "vscode:prepublish": "pnpm run build:extension"
  },
  "keywords": [
    "agent",
    "network",
    "diagnostics",
    "vscode"
  ],
  "author": "",
  "license": "Apache-2.0",
  "packageManager": "pnpm@10.33.0",
  "dependencies": {
    "@agent-anything/agent-core": "workspace:*",
    "@agent-anything/evidence": "workspace:*",
    "@agent-anything/observability": "workspace:*",
    "@agent-anything/permission": "workspace:*",
    "@agent-anything/providers": "workspace:*",
    "@agent-anything/shared": "workspace:*",
    "@agent-anything/storage": "workspace:*",
    "@agent-anything/tools": "workspace:*"
  },
  "devDependencies": {
    "@agent-anything/testing": "workspace:*",
    "@types/node": "^25.9.1",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.9.2",
    "esbuild": "^0.28.0"
  }
}
