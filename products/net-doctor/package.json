{
  "name": "net-doctor",
  "displayName": "NetDoctor",
  "version": "0.0.0",
  "publisher": "agent-anything",
  "type": "module",
  "description": "NetDoctor, a VS Code-based network diagnostic agent built on AgentAnything.",
  "categories": [
    "Other"
  ],
  "engines": {
    "vscode": "^1.90.0"
  },
  "activationEvents": [
    "onCommand:netDoctor.diagnoseTarget"
  ],
  "main": "./dist/extension.js",
  "types": "./dist/extension.d.ts",
  "contributes": {
    "commands": [
      {
        "command": "netDoctor.diagnoseTarget",
        "title": "NetDoctor: Diagnose Target"
      }
    ]
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "vscode:prepublish": "pnpm run build"
  },
  "keywords": [
    "agent",
    "network",
    "diagnostics",
    "vscode"
  ],
  "author": "",
  "license": "Apache-2.0",
  "packageManager": "pnpm@10.33.0",
  "dependencies": {
    "@agent-anything/platform": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/vscode": "^1.120.0"
  }
}
