{
    "name":  "@agent-anything/helarc",
    "version":  "0.0.0",
    "description":  "Helarc product composition for the AgentAnything developer workbench.",
    "type":  "module",
    "main":  "./dist/index.js",
    "types":  "./src/index.ts",
    "exports":  {
                    ".":  {
                              "types":  "./src/index.ts",
                              "import":  "./dist/index.js"
                          }
                },
    "files":  [
                  "dist"
              ],
    "scripts":  {
                    "build":  "tsc -p tsconfig.json",
                    "typecheck":  "tsc -p tsconfig.json --noEmit",
                    "test":  "vitest run --passWithNoTests"
                },
    "license":  "Apache-2.0",
    "private":  true,
    "dependencies":  {
                         "@agent-anything/agent-core":  "workspace:*",
                         "@agent-anything/agent-runtime":  "workspace:*",
                         "@agent-anything/code-agent":  "workspace:*",
                         "@agent-anything/evidence":  "workspace:*",
                         "@agent-anything/governance":  "workspace:*",
                         "@agent-anything/host":  "workspace:*",
                         "@agent-anything/permission":  "workspace:*",
                         "@agent-anything/providers":  "workspace:*",
                         "@agent-anything/shared":  "workspace:*",
                         "@agent-anything/storage":  "workspace:*",
                         "@agent-anything/tools":  "workspace:*"
                     },
    "devDependencies":  {
                            "@types/node":  "^25.9.1"
                        }
}
